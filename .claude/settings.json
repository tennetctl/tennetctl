{
  "mcpServers": {
    "playwright": {
      "command": "/opt/homebrew/bin/npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "type": "stdio"
    },
    "code-review-graph": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--with",
        "sentence-transformers",
        "code-review-graph",
        "serve"
      ],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "type": "stdio"
    },
    "context-mode": {
      "command": "npx",
      "args": ["-y", "context-mode"],
      "type": "stdio"
    }
  }
}
