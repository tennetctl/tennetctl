{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx block-no-verify@1.1.2"
          }
        ],
        "description": "Block git hook-bypass flags"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/sri/Documents/ss-factory/.claude node /Users/sri/Documents/ss-factory/.claude/scripts/hooks/run-with-flags.js \"pre:bash:git-push-reminder\" \"scripts/hooks/pre-bash-git-push-reminder.js\" \"standard,strict\""
          }
        ],
        "description": "Reminder before git push to review changes"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/sri/Documents/ss-factory/.claude node /Users/sri/Documents/ss-factory/.claude/scripts/hooks/run-with-flags.js \"pre:edit-write:suggest-compact\" \"scripts/hooks/suggest-compact.js\" \"standard,strict\""
          }
        ],
        "description": "Suggest manual compaction at logical intervals"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/sri/Documents/ss-factory/.claude node /Users/sri/Documents/ss-factory/.claude/scripts/hooks/run-with-flags.js \"pre:config-protection\" \"scripts/hooks/config-protection.js\" \"standard,strict\"",
            "timeout": 5
          }
        ],
        "description": "Block modifications to linter/formatter config files"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/sri/Documents/ss-factory/.claude node /Users/sri/Documents/ss-factory/.claude/scripts/hooks/run-with-flags.js \"post:bash:pr-created\" \"scripts/hooks/post-bash-pr-created.js\" \"standard,strict\""
          }
        ],
        "description": "Log PR URL after PR creation"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/sri/Documents/ss-factory/.claude/hooks/format-python.sh"
          }
        ],
        "description": "Auto-format Python files with ruff after edits"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/sri/Documents/ss-factory/.claude node /Users/sri/Documents/ss-factory/.claude/scripts/hooks/run-with-flags.js \"post:edit:format\" \"scripts/hooks/post-edit-format.js\" \"standard,strict\""
          }
        ],
        "description": "Auto-format JS/TS files with Biome/Prettier after edits"
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/sri/Documents/ss-factory/.claude node /Users/sri/Documents/ss-factory/.claude/scripts/hooks/run-with-flags.js \"post:edit:console-warn\" \"scripts/hooks/post-edit-console-warn.js\" \"standard,strict\""
          }
        ],
        "description": "Warn about console.log statements after edits"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/sri/Documents/ss-factory/.claude node /Users/sri/Documents/ss-factory/.claude/scripts/hooks/run-with-flags.js \"stop:check-console-log\" \"scripts/hooks/check-console-log.js\" \"standard,strict\""
          }
        ],
        "description": "Check for console.log in modified files"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/sri/Documents/ss-factory/.claude node /Users/sri/Documents/ss-factory/.claude/scripts/hooks/run-with-flags.js \"stop:session-end\" \"scripts/hooks/session-end.js\" \"minimal,standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Persist session state after each response"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/sri/Documents/ss-factory/.claude node /Users/sri/Documents/ss-factory/.claude/scripts/hooks/run-with-flags.js \"stop:desktop-notify\" \"scripts/hooks/desktop-notify.js\" \"standard,strict\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "macOS desktop notification when Claude responds"
      }
    ]
  }
}
